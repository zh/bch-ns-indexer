PORT=3100

# -- Option A: consumer-api (local psf-bch-api / JSON-RPC) --
BCH_INTERFACE=consumer-api
BCH_REST_URL=http://192.168.0.3:5942/v6

# -- Option B: rest-api (FullStack.cash direct REST) --
# BCH_INTERFACE=rest-api
# BCH_REST_URL=https://api.fullstack.cash/v5/

START_BLOCK=850000
# Local: ./data/bchns.sqlite
# Railway: /data/bchns.sqlite (persistent volume)
DB_PATH=./data/bchns.sqlite
# Delay (ms) between scanning blocks. Default 15000 for free-tier rate limits.
# Set to 0 when running against a local node or paid API.
SCAN_DELAY_MS=15000
