PORT=3100

# -- Scanner config (blockchain scanning backend) --
# consumer-api = consumer protocol (rest-api cannot get blocks info)
BCH_INTERFACE=consumer-api
BCH_REST_URL=https://api.fullstack.cash/v5/

# -- Alternative: local psf-bch-api --
# BCH_REST_URL=http://192.168.0.10:5942/v6

START_BLOCK=850000
DB_PATH=./data/bchns.sqlite
SCAN_DELAY_MS=15000

# -- Wallet config (for CLI scripts: create/update/delete/transfer) --
# rest-api     = direct REST (local psf-bch-api)
# consumer-api = consumer protocol (api.fullstack.cash, free-bch.fullstack.cash)
WALLET_INTERFACE=consumer-api
WALLET_REST_URL=https://free-bch.fullstack.cash

# -- Wallet with local node --
# WALLET_INTERFACE=rest-api
# WALLET_REST_URL=http://192.168.0.3:5942/v6
